# Copia este fichero a .env y rellena los valores

# Clave secreta para JWT — cámbiala en producción
SECRET_KEY=cambia-esto-en-produccion

# Credenciales del primer usuario administrador
# Se crea automáticamente al arrancar si no hay ningún admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu-password-seguro

# Expiración del token de acceso (minutos). 10080 = 7 días
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Días que duran las invitaciones
INVITE_EXPIRE_DAYS=7

# Puerto en el que escucha la app en el host
APP_PORT=8080

# GitHub token para aumentar el límite de la API (60 req/h → 5000 req/h)
# Genera uno en: https://github.com/settings/tokens (no necesita permisos extra)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
